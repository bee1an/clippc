# Client-side defaults
# Leave empty by default. UI should accept an OpenAI-compatible upstream Base URL.
# /api/ai is an internal proxy route and is not recommended for direct UI input.
VITE_AI_BASE_URL=
VITE_AI_MODEL=

# Server-side managed upstream (Cloudflare Pages Function / local Vite proxy)
AI_MANAGED_UPSTREAM=https://integrate.api.nvidia.com/v1

# Managed key mode secret (Cloudflare Pages Secret / local Vite proxy)
# Required when using server-side managed key mode.
# BYOK mode remains optional and user-provided.
AI_MANAGED_API_KEY=

# Managed mode accepts server-configured local http/private upstreams.
# Optional: only enable for trusted local debugging in BYOK mode.
# When true, proxy allows http://localhost upstream in BYOK mode.
# AI_PROXY_ALLOW_LOCALHOST_HTTP=false

# Pexels managed API key (Cloudflare Pages Secret / local Vite proxy)
PEXELS_API_KEY=
# Optional: override Pexels upstream base.
# PEXELS_API_BASE=https://api.pexels.com
